# Optional PostgreSQL connection. If empty, RelayWatch reads local JSON data files.
DATABASE_URL=postgresql://relaywatch:change-me@127.0.0.1:5432/relaywatch

# Admin token for protected maintenance endpoints.
RELAYWATCH_ADMIN_TOKEN=change-me

# Optional detector service used by the model/site detection page.
RELAYWATCH_DETECTOR_BASE_URL=http://127.0.0.1:8770
RELAYWATCH_DETECTOR_TIMEOUT=20
RELAYWATCH_QUALITY_PROBE_TIMEOUT=18

# Optional GitHub token for higher AI project/news collection rate limits.
GITHUB_TOKEN=
RELAYWATCH_GITHUB_TOKEN=

# Optional LinuxDo cookie or custom RSS list for feeds behind Cloudflare.
RELAYWATCH_LINUXDO_COOKIE=
RELAYWATCH_LINUXDO_RSS_URLS=https://linux.do/latest.rss,https://linux.do/top.rss,https://linux.do/posts.rss

# Caches and API tuning.
REDIS_URL=
RELAYWATCH_REDIS_PREFIX=relaywatch
RELAYWATCH_REDIS_RETRY_INTERVAL=60
RELAYWATCH_OFFICIAL_STATUS_TTL=300
RELAYWATCH_AI_NEWS_TTL=900
RELAYWATCH_AI_NEWS_PER_FEED=12
RELAYWATCH_MODEL_RESULT_CACHE_MAX=256
RELAYWATCH_SITE_RESULT_CACHE_MAX=256
RELAYWATCH_META_CACHE_TTL=1800
RELAYWATCH_DB_STATEMENT_TIMEOUT_MS=8000
